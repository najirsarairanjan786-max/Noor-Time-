rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || request.auth.token.email == 'naziralquran786@gmail.com');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidNote(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt', 'updatedAt', 'userId'])
        && data.keys().size() == 5
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 50000
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.userId == request.auth.uid;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'photoURL', 'email', 'phone', 'address', 'location', 'state', 'pinCode', 'country', 'updatedAt', 'userId'])
        && data.keys().size() == 12
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.photoURL is string && data.photoURL.size() <= 1024
        && data.email is string && data.email.size() <= 100
        && data.phone is string && data.phone.size() <= 50
        && data.address is string && data.address.size() <= 200
        && data.location is string && data.location.size() <= 100
        && data.state is string && data.state.size() <= 100
        && data.pinCode is string && data.pinCode.size() <= 20
        && data.country is string && data.country.size() <= 100
        && data.updatedAt is timestamp
        && data.userId == request.auth.uid;
    }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt', 'updatedBy'])
        && data.keys().size() == 4
        && data.email is string && data.email.size() <= 100
        && data.role is string && data.role.matches('^(superadmin|admin|editor)$')
        && data.createdAt is timestamp
        && data.updatedBy is string && data.updatedBy.size() <= 128;
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'url', 'category', 'thumbnail', 'featured', 'views', 'createdAt', 'updatedAt'])
        && data.keys().size() == 8
        && data.title is string && data.title.size() <= 200
        && data.url is string && data.url.size() <= 1024
        && data.category is string && data.category.size() <= 100
        && data.thumbnail is string && data.thumbnail.size() <= 1024
        && data.featured is bool
        && data.views is number
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'description', 'category', 'stockStatus', 'featured', 'image', 'link', 'createdAt'])
        && data.keys().size() == 9
        && data.name is string && data.name.size() <= 200
        && data.price is number
        && data.description is string && data.description.size() <= 5000
        && data.category is string && data.category.size() <= 100
        && data.stockStatus is string && data.stockStatus.matches('^(in_stock|out_of_stock)$')
        && data.featured is bool
        && data.image is string && data.image.size() <= 1024
        && data.link is string && data.link.size() <= 1024
        && data.createdAt is timestamp;
    }

    function isValidApkRelease(data) {
      return data.keys().hasAll(['version', 'url', 'size', 'notes', 'forceUpdate', 'createdAt'])
        && data.keys().size() == 6
        && data.version is string && data.version.size() <= 50
        && data.url is string && data.url.size() <= 1024
        && data.size is string && data.size.size() <= 50
        && data.notes is string && data.notes.size() <= 5000
        && data.forceUpdate is bool
        && data.createdAt is timestamp;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'message', 'category', 'scheduledFor', 'status', 'createdAt'])
        && data.keys().size() == 6
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.category is string && data.category.size() <= 100
        && data.scheduledFor is timestamp
        && data.status is string && data.status.matches('^(pending|sent|failed)$')
        && data.createdAt is timestamp;
    }

    function isValidContent(data) {
      return data.keys().hasAll(['type', 'title', 'body', 'author', 'imageUrl', 'createdAt'])
        && data.keys().size() == 6
        && data.type is string && data.type.matches('^(hadith|article|quote|banner)$')
        && data.title is string && data.title.size() <= 200
        && data.body is string && data.body.size() <= 50000
        && data.author is string && data.author.size() <= 100
        && data.imageUrl is string && data.imageUrl.size() <= 1024
        && data.createdAt is timestamp;
    }

    function isValidAppSetting(data) {
      return data.keys().hasAll(['appName', 'appLogo', 'splashScreen', 'admobAppId', 'admobBannerId', 'admobInterstitialId', 'socialLinks', 'contactInfo', 'modifiedAt'])
        && data.keys().size() == 9
        && data.appName is string && data.appName.size() <= 100
        && data.appLogo is string && data.appLogo.size() <= 1024
        && data.splashScreen is string && data.splashScreen.size() <= 1024
        && data.admobAppId is string && data.admobAppId.size() <= 200
        && data.admobBannerId is string && data.admobBannerId.size() <= 200
        && data.admobInterstitialId is string && data.admobInterstitialId.size() <= 200
        && data.socialLinks is string && data.socialLinks.size() <= 2000
        && data.contactInfo is string && data.contactInfo.size() <= 2000
        && data.modifiedAt is timestamp;
    }

    function isValidContactMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'status', 'createdAt'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.message is string && data.message.size() <= 5000
        && data.status is string && data.status.matches('^(unread|read)$')
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && isValidId(userId) && (userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() && isValidId(userId);
      
      allow create: if isSignedIn()
                    && isValidId(userId)
                    && userId == request.auth.uid
                    && isValidUserProfile(incoming())
                    && incoming().updatedAt == request.time;
                    
      allow update: if isSignedIn()
                    && isValidId(userId)
                    && (userId == request.auth.uid || isAdmin())
                    && existing().userId == userId
                    && incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'lastName', 'photoURL', 'email', 'phone', 'address', 'location', 'state', 'pinCode', 'country', 'updatedAt'])
                    && isValidUserProfile(incoming())
                    && incoming().updatedAt == request.time;

      match /noor_messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /notes/{noteId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(noteId) && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
                    && isValidId(noteId) 
                    && isValidNote(incoming()) 
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;

      allow update: if isSignedIn() 
                    && isValidId(noteId) 
                    && existing().userId == request.auth.uid
                    && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'updatedAt'])
                    && incoming().title is string && incoming().title.size() <= 200
                    && incoming().content is string && incoming().content.size() <= 50000
                    && incoming().updatedAt == request.time;
      
      allow delete: if isSignedIn() 
                    && isValidId(noteId) 
                    && existing().userId == request.auth.uid;
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(adminId) && isValidAdmin(incoming());
      allow update: if isAdmin() && isValidId(adminId) && isValidAdmin(incoming());
      allow delete: if isAdmin() && isValidId(adminId);
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(videoId) && isValidVideo(incoming());
      allow update: if isAdmin() && isValidId(videoId) && isValidVideo(incoming());
      allow delete: if isAdmin() && isValidId(videoId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow delete: if isAdmin() && isValidId(productId);
    }

    match /apk_releases/{releaseId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(releaseId) && isValidApkRelease(incoming());
      allow update: if isAdmin() && isValidId(releaseId) && isValidApkRelease(incoming());
      allow delete: if isAdmin() && isValidId(releaseId);
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(notificationId) && isValidNotification(incoming());
      allow update: if isAdmin() && isValidId(notificationId) && isValidNotification(incoming());
      allow delete: if isAdmin() && isValidId(notificationId);
    }

    match /content/{contentId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(contentId) && isValidContent(incoming());
      allow update: if isAdmin() && isValidId(contentId) && isValidContent(incoming());
      allow delete: if isAdmin() && isValidId(contentId);
    }

    match /app_settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(settingId) && isValidAppSetting(incoming());
      allow update: if isAdmin() && isValidId(settingId) && isValidAppSetting(incoming());
      allow delete: if isAdmin() && isValidId(settingId);
    }

    match /contact_messages/{messageId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
